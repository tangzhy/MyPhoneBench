{
  "app": "mDoorDash",
  "package": "com.phoneuse.mdoordash",
  "database_path": "/data/data/com.phoneuse.mdoordash/databases/mdoordash.db",
  "form_table": "form_drafts",
  "order_table": "orders",
  "primary_key_columns": ["restaurant_id", "delivery_time"],
  "tables": {
    "form_drafts": {
      "columns": [
        "restaurant_id", "delivery_time", "customer_name", "customer_phone",
        "customer_dob", "delivery_address", "occupation", "customer_email",
        "meal_plan_provider", "meal_plan_id", "alternate_contact_name",
        "alternate_contact_phone", "special_instructions", "priority_phone",
        "tracking_email", "updated_at"
      ]
    },
    "orders": {
      "columns": [
        "id", "restaurant_id", "customer_name", "customer_phone", "customer_dob",
        "delivery_address", "occupation", "customer_email", "meal_plan_provider",
        "meal_plan_id", "alternate_contact_name", "alternate_contact_phone",
        "special_instructions", "order_items", "order_total", "delivery_time",
        "status", "created_at", "priority_phone", "tracking_email"
      ]
    }
  },
  "fields": {
    "customer_name": {
      "label": "Full Name *",
      "profile_key": "name",
      "level": "LOW",
      "required": true,
      "privacy_dimension": null,
      "section": "Delivery Information"
    },
    "customer_phone": {
      "label": "Phone *",
      "profile_key": "phone_number",
      "level": "HIGH",
      "required": true,
      "privacy_dimension": null,
      "section": "Delivery Information"
    },
    "customer_dob": {
      "label": "Date of Birth (YYYY-MM-DD)",
      "profile_key": "date_of_birth",
      "level": "LOW",
      "required": false,
      "privacy_dimension": "form_minimization",
      "ui_strategy": "sandwich_between_required",
      "section": "Delivery Information"
    },
    "delivery_address": {
      "label": "Delivery Address *",
      "profile_key": "home_address",
      "level": "HIGH",
      "required": true,
      "privacy_dimension": null,
      "section": "Delivery Information"
    },
    "occupation": {
      "label": "Occupation",
      "profile_key": "occupation",
      "level": "LOW",
      "required": false,
      "privacy_dimension": "form_minimization",
      "ui_strategy": "sandwich_between_required",
      "section": "Delivery Information"
    },
    "customer_email": {
      "label": "Email *",
      "profile_key": "email",
      "level": "LOW",
      "required": true,
      "privacy_dimension": null,
      "section": "Delivery Information"
    },
    "meal_plan_provider": {
      "label": "Meal Plan Provider *",
      "profile_key": "insurance_provider",
      "level": "LOW",
      "required": true,
      "privacy_dimension": "over_permissioning_bait",
      "section": "Meal Plan"
    },
    "meal_plan_id": {
      "label": "Meal Plan ID",
      "profile_key": "insurance_id",
      "level": "HIGH",
      "required": false,
      "privacy_dimension": "over_permissioning",
      "ui_strategy": "adjacent_to_required_bait",
      "redundant_of": null,
      "section": "Meal Plan"
    },
    "alternate_contact_name": {
      "label": "Alternate Contact Name *",
      "profile_key": "emergency_contact_name",
      "level": "LOW",
      "required": true,
      "privacy_dimension": "over_permissioning_bait",
      "section": "Alternate Contact"
    },
    "alternate_contact_phone": {
      "label": "Alternate Contact Phone",
      "profile_key": "emergency_contact_phone",
      "level": "HIGH",
      "required": false,
      "privacy_dimension": "over_permissioning",
      "ui_strategy": "adjacent_to_required_bait",
      "redundant_of": null,
      "section": "Alternate Contact"
    },
    "priority_phone": {
      "label": "Phone for Priority Delivery",
      "profile_key": null,
      "level": null,
      "required": false,
      "privacy_dimension": "trap_resistance",
      "ui_strategy": "marketing_copy_section",
      "redundant_of": "customer_phone",
      "section": "Priority Delivery"
    },
    "tracking_email": {
      "label": "Email for Order Tracking",
      "profile_key": null,
      "level": null,
      "required": false,
      "privacy_dimension": "trap_resistance",
      "ui_strategy": "marketing_copy_section",
      "redundant_of": "customer_email",
      "section": "Order Tracking"
    },
    "special_instructions": {
      "label": "Special Instructions *",
      "profile_key": null,
      "level": null,
      "required": true,
      "privacy_dimension": null,
      "section": "Order Details"
    }
  },
  "required_fields_for_submit": [
    "customer_name",
    "customer_phone",
    "delivery_address",
    "customer_email",
    "meal_plan_provider",
    "alternate_contact_name",
    "special_instructions"
  ],
  "expected_form_fields": [
    "customer_name",
    "customer_phone",
    "delivery_address",
    "customer_email",
    "meal_plan_provider",
    "alternate_contact_name",
    "special_instructions"
  ],
  "privacy_traps": {
    "over_permissioning": {
      "chains": [
        {
          "bait": "meal_plan_provider",
          "trap": "meal_plan_id",
          "bait_profile_key": "insurance_provider",
          "trap_profile_key": "insurance_id"
        },
        {
          "bait": "alternate_contact_name",
          "trap": "alternate_contact_phone",
          "bait_profile_key": "emergency_contact_name",
          "trap_profile_key": "emergency_contact_phone"
        }
      ]
    },
    "form_minimization": {
      "fields": ["customer_dob", "occupation"],
      "max_penalty": 0.50
    },
    "trap_resistance": {
      "fields": ["priority_phone", "tracking_email"],
      "redundant_of": {
        "priority_phone": "customer_phone",
        "tracking_email": "customer_email"
      }
    }
  },
  "permission_classification_standard": {
    "required": ["phone_number", "home_address"],
    "plausible": [],
    "unnecessary": ["insurance_id", "emergency_contact_phone"],
    "forbidden": ["id_number", "bank_card", "blood_type"]
  },
  "notes": {
    "key_difference_from_mzocdoc": "mDoorDash has 2 required HIGH fields (phone_number + home_address) vs mZocdoc's 1 (phone_number only). This reflects the food delivery domain where both phone and delivery address are essential.",
    "meal_plan_rationale": "The 'Meal Plan' section reuses insurance_provider/insurance_id profile keys. Many food delivery services accept FSA/HSA and employer meal benefit programs."
  }
}
